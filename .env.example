# =============================================================================
# DigitalMate 环境变量模板
#
# 使用方式：
#   cp .env.example .env
#   然后编辑 .env，填入你的 API Key 和配置
#
# 详细说明见 docs/env.md
# 切勿将 .env 提交到 Git
# =============================================================================

# -----------------------------------------------------------------------------
# KIE.AI 统一 API（Gemini / Claude 共用）
# 控制台：https://kie.ai
# -----------------------------------------------------------------------------
KIE_AI_API_KEY=
KIE_AI_BASE_URL=https://api.kie.ai

# -----------------------------------------------------------------------------
# Web 应用与数据库
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://digitalmate:digitalmate@localhost:5432/digitalmate
APP_PASSWORD=
APP_SECRET=digitalmate-local-secret-change-me
TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# 阿里云 IQS 检索增强（联网搜索 / 网页解析）
# 控制台：https://iqs.console.aliyun.com/api-keys
# 接入文档：docs/api/阿里云检索增强IQS接入文档.md
# 鉴权：Authorization: Bearer <ALIYUN_IQS_API_KEY>
# -----------------------------------------------------------------------------
ALIYUN_IQS_API_KEY=
ALIYUN_IQS_BASE_URL=https://cloud-iqs.aliyuncs.com

# -----------------------------------------------------------------------------
# 搜索与主动性参数
# -----------------------------------------------------------------------------
# 搜索提供商：duckduckgo（默认占位）| iqs（阿里云 IQS，需填入上方 API Key）
SEARCH_PROVIDER=duckduckgo
PROACTIVE_QUIET_START=23:00
PROACTIVE_QUIET_END=08:00
PROACTIVE_MAX_PER_DAY=3

# -----------------------------------------------------------------------------
# P1 IM 渠道
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
DINGTALK_ROBOT_CODE=

# -----------------------------------------------------------------------------
# Gemini 3.5 Flash（OpenAI 兼容格式）
# 接入文档：docs/api/gemini3-5-flash接入文档.md
# 鉴权：Authorization: Bearer <KIE_AI_API_KEY>
# -----------------------------------------------------------------------------
GEMINI_3_5_FLASH_ENDPOINT=/gemini-3-5-flash-openai/v1/chat/completions

# -----------------------------------------------------------------------------
# Claude Opus 4.6 / 4.8（Anthropic Messages API）
# 接入文档：
#   docs/api/claude-opus-4-6接入文档.md
#   docs/api/claude-opus-4-8接入文档.md
# 鉴权：Authorization: Bearer <KIE_AI_API_KEY>，请求头需带 anthropic-version
# -----------------------------------------------------------------------------
CLAUDE_MESSAGES_ENDPOINT=/claude/v1/messages
ANTHROPIC_API_VERSION=2023-06-01

# -----------------------------------------------------------------------------
# 模型路由（实现阶段按用途选用，见 PRD 7.3）
# -----------------------------------------------------------------------------
# 主对话 / 复杂任务
LLM_MODEL_MAIN=claude-opus-4-8
# 高频轻量调用（插话判断、记忆抽取等）
LLM_MODEL_LIGHT=gemini-3-5-flash-openai

# -----------------------------------------------------------------------------
# 记忆向量 Embedding（可选，OpenAI 兼容 /embeddings 接口）
# 不配置时降级为本地伪向量（召回质量下降，但功能可用）
# 维度必须与 schema.sql 中 vector(1536) 一致
# -----------------------------------------------------------------------------
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1536
